# kizuna/api — Generated by @kagami/env — edit src/env.ts and run `npm run env:gen`.

# MongoDB connection (`mongodb://` or `mongodb+srv://`).
MONGODB_URI=mongodb://127.0.0.1:27017/kizuna

# Comma-separated list of the operator's own email addresses (lowercased,
# each validated). The ingest workers use it for "self" detection — which
# side of an email or event is me. It is not an authentication boundary.
USER_EMAILS=you@example.com

# === Kao (Google identity) ===

# Kao identity service origin; short-lived Google access tokens are vended
# from ${KAO_URL}/grants/<consumer>/token. Set together with KAO_TOKEN.
# KAO_URL=https://api.kao.localhost

# Bearer presented to Kao's /grants/* vend surface (≥16 chars).
# KAO_TOKEN=

# Extra browser Origin values allowed to POST /oauth/google/start (CSRF
# allowlist), comma-separated. https://kizuna.localhost is always allowed;
# set this only when the dashboard runs on a different origin (renamed
# Portless host, bare-port debug, SSH tunnel, staging deploy).
KIZUNA_DASHBOARD_ORIGIN=

# Comma-separated sender domains to skip during Gmail ingest (newsletter
# noise), lowercased.
NEWSLETTER_DOMAIN_BLOCKLIST=

# Initial Gmail backfill horizon in days (1–365). Applies only on the
# worker's first (bootstrap) run; incremental runs use cursors.
KIZUNA_GMAIL_BACKFILL_DAYS=30

# Initial Calendar backfill horizon in days (1–365). Applies only on the
# worker's first (bootstrap) run; incremental runs use cursors.
KIZUNA_GCAL_BACKFILL_DAYS=60

# Ingest scheduler period in seconds (0–86400). 0 disables the in-process
# scheduler entirely — manual triggers via POST /sync/{gmail,gcal}/run still
# work. Set to 300 (5 min) for typical dev use.
KIZUNA_INGEST_INTERVAL_SEC=0

# === Standalone fallback ===

# Standalone fallback bind host. Portless injects PORT and proxies
# https://api.kizuna.localhost; these only matter running outside Portless.
KIZUNA_HOST=127.0.0.1

# Standalone fallback bind port (Portless injects its own otherwise).
PORT=3000

# === Logging ===

# Pino log level (`silent` in tests).
LOG_LEVEL=info

# === Kansoku (observability) ===

# Ship every log line to the workspace's Kansoku service alongside stdout.
# Both Kansoku vars must be set together — either missing leaves the logger
# stdout-only (fail-open; observability failure never wedges this service).
# KANSOKU_URL=https://api.kansoku.localhost

# Shared HMAC token the Kansoku ingest surface requires.
# KANSOKU_INGEST_TOKEN=
