MONGODB_URI=mongodb://127.0.0.1:27017/kizuna
USER_EMAILS=you@example.com

# === Kao (Google identity) ===
# Google access (Gmail + Calendar, read-only) is vended by the Kao identity
# service — Kizuna no longer owns a refresh token. Set both vars together;
# consent is granted at ${KAO_URL}/oauth/kizuna/start (operator browser).
# When unset, the /sync and /oauth routes return 400 and the dashboard's
# "Connect Google" button is the next step.
# KAO_URL=https://api.kao.localhost
# KAO_TOKEN=your_kao_bearer_here

# Extra browser origins allowed to POST /oauth/google/start (CSRF Origin
# allowlist). https://kizuna.localhost is always allowed; set this only if
# the dashboard runs on a different origin. Comma-separated; default empty.
# KIZUNA_DASHBOARD_ORIGIN=

NEWSLETTER_DOMAIN_BLOCKLIST=
KIZUNA_GMAIL_BACKFILL_DAYS=30
KIZUNA_GCAL_BACKFILL_DAYS=60
# 0 disables the in-process scheduler. Set to 300 (5 min) for typical dev use.
KIZUNA_INGEST_INTERVAL_SEC=0
# Standalone fallback host. Portless injects PORT and proxies https://api.kizuna.localhost.
KIZUNA_HOST=127.0.0.1
LOG_LEVEL=info

# === Kansoku (observability) ===
# Ship every log line to the workspace's Kansoku service alongside stdout.
# Both vars must be set together — either missing leaves the logger
# stdout-only (graceful in dev and during the Kansoku rollout window).
# Use the same KANSOKU_INGEST_TOKEN value across services; rotate by
# updating each .env and restarting.
# KANSOKU_URL=https://api.kansoku.localhost
# KANSOKU_INGEST_TOKEN=
