# Vault directory. Defaults to ./memory under the project root.
BRAINIAC_VAULT=./memory

# Local LLM endpoint (OpenAI-compatible). LM Studio default is :1234.
LMSTUDIO_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio

# Model name as exposed by your local server. Whatever you've loaded.
MODEL=
