KIZUNA_API_KEY=replace-with-a-long-random-token
MONGO_URI=mongodb://127.0.0.1:27017/kizuna
USER_EMAILS=you@example.com
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
