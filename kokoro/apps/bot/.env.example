# ─────────────────────────────────────────────────────────────
# Kokoro bot — copy to apps/bot/.env and fill in.
# Anything left commented falls back to the default in
# packages/shared/src/config.ts. Validation runs at startup.
# ─────────────────────────────────────────────────────────────


# ── Required ──────────────────────────────────────────────────

# Telegram (primary platform)
TELEGRAM_BOT_TOKEN=your_bot_token_here
ALLOWED_USER_IDS=123456789,987654321

# MongoDB
MONGODB_URI=mongodb://localhost:27017/kokoro

# Kioku (long-term memory service). Defaults to https://api.kioku.localhost (Portless).
# Use http://localhost:7777 only when running Kioku standalone (its bind-port fallback).
# KIOKU_URL=https://api.kioku.localhost

# Kizuna (CRM context + confirmation-gated writes). Defaults to https://api.kizuna.localhost (Portless).
# Use http://localhost:3000 only when running Kizuna API standalone (its bind-port fallback).
# CRM tools are always registered; reads/writes fail open if Kizuna is unreachable.
# KIZUNA_URL=https://api.kizuna.localhost

# LLM (chat goes through the @kagami/llm gateway — native providers only)
LLM_KIND=native                        # native (only supported value for Kokoro chat)
LLM_PROVIDER=anthropic                 # anthropic | openai | xai
LLM_MODEL=claude-sonnet-4-6            # the Default tier
# Optional tier overrides — unset = per-provider defaults (anthropic:
# claude-haiku-4-5 / claude-sonnet-4-6). Used by getModel(Fast|Smart).
# LLM_MODEL_FAST=claude-haiku-4-5
# LLM_MODEL_SMART=claude-sonnet-4-6
# Per-attempt chat deadline (ms). The @kagami/llm gateway aborts and retries an
# attempt that exceeds this, so a slow/hung provider response fails over fast
# instead of eating the conversational turn budget. This is the per-attempt cap,
# NOT the turn budget. Default 30000.
# LLM_ATTEMPT_TIMEOUT_MS=30000
ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENAI_API_KEY=your_openai_key_here  # required when LLM_PROVIDER=openai
# XAI_API_KEY=your_xai_key_here        # required when LLM_PROVIDER=xai
# GOOGLE_API_KEY=your_google_ai_studio_key_here  # required when IMAGE_GENERATION_MODEL=google/...


# ── App ───────────────────────────────────────────────────────

LOG_LEVEL=info                         # fatal | error | warn | info | debug | trace
NODE_ENV=development                   # development | production | test
# TIMEZONE=America/New_York            # IANA tz; used for prompts, schedulers, calendar formatting
# CONTEXT_PATH=./context               # location of soul.md and reference images


# ── Optional: image generation ────────────────────────────────

# Format: "provider/model". Provider keys are reused from the LLM section
# (so xai/* needs XAI_API_KEY above, etc.). When unset, the sendPhoto tool
# is omitted from Kokoro's tool palette.
# IMAGE_GENERATION_MODEL=xai/grok-imagine-image


# ── Optional: voice ───────────────────────────────────────────

# Inbound speech-to-text — see docs/voice.md
# Local whisper.cpp (default mode): point STT_BASE_URL at the local
# OpenAI-compatible server. STT_API_KEY can be any non-empty string for
# whisper.cpp servers that don't enforce auth.
# STT_PROVIDER=openai/whisper-1
# STT_BASE_URL=http://127.0.0.1:8089/v1
# STT_API_KEY=local

# Outbound text-to-speech — sendVoice tool
# TTS_PROVIDER=elevenlabs/eleven_v3
# TTS_VOICE_ID=your_elevenlabs_voice_id_here
# ELEVENLABS_API_KEY=your_elevenlabs_api_key_here


# ── Optional: Google services via Kao (email + calendar + reminders) ──

# Google access is vended by the Kao identity service — Kokoro no longer
# owns a refresh token. Set both vars together; consent is granted at
# ${KAO_URL}/oauth/kokoro/start (operator browser). The 'kokoro' grant in
# Kao's registry is consented for: gmail.readonly + gmail.send + calendar.
# When unset, the email/calendar/reminder tools and the maid-service
# instructions are dropped from the LLM context entirely.
# KAO_URL=https://api.kao.localhost
# KAO_TOKEN=your_kao_bearer_here


# ── Optional: web search ──────────────────────────────────────
# Brave Search API. Free tier: 2000 queries/month, 1 query/sec.
# When set, the LLM gets a fast no-browser webSearch tool and the
# in-browser `search` action is dropped from the browse tool.
# https://brave.com/search/api/
# BRAVE_SEARCH_API_KEY=your_brave_api_key_here

# ── Browser tool (always on; configure mode below) ───────────

# BROWSER_ENV=local                    # local (Playwright Chromium) | cloud (Browserbase)
# BROWSER_MODEL=anthropic/claude-haiku-4-5
# BROWSER_GEOLOCATION=40.7128,-74.0060 # lat,lng for emulated geolocation
# BROWSER_HEADLESS=true
# BROWSER_DATA_DIR=./data/browser
# BROWSERBASE_API_KEY=your_browserbase_api_key_here       # required when BROWSER_ENV=cloud
# BROWSERBASE_PROJECT_ID=your_browserbase_project_id_here


# ── Optional: sandboxed code execution ────────────────────────

# executeCode tool: runs LLM-written Python/Node scripts in a locked-down
# ephemeral Docker container (no network, empty env, read-only rootfs,
# memory/CPU/pid caps). Requires a local Docker daemon at runtime; the tool
# fails open per call when the daemon is down. Every run is tap-to-approve
# and the bubble shows the full code. Unset = tool not registered.
# EXECUTE_CODE_ENABLED=true
# EXECUTE_CODE_PYTHON_IMAGE=python:3.12-slim
# EXECUTE_CODE_NODE_IMAGE=node:22-slim
# EXECUTE_CODE_TIMEOUT_MS=120000       # wall-clock cap per run
# EXECUTE_CODE_MEMORY_MB=512           # hard memory cap (swap pinned to the same value)


# ── Location awareness (always on) ────────────────────────────

# GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here       # optional; without it, geocoding degrades to raw coordinates
# LOCATION_MOVEMENT_THRESHOLD_M=100
# LOCATION_PROACTIVE_DELAY_MS=1200000
# LOCATION_CONTEXT_MAX_AGE_H=12
# PLACE_LEARNING_VISITS=3
# PLACE_LEARNING_RADIUS_M=200
# PLACE_LEARNING_WINDOW_DAYS=30


# ── Optional: iMessage adapter via BlueBubbles ────────────────

# See docs/imessage.md. Telegram and iMessage can run side-by-side.
# BLUEBUBBLES_HOST sets the BlueBubbles server URL; password authenticates
# both outbound API calls and inbound webhook posts.
# BLUEBUBBLES_HOST=http://192.168.1.10:1234
# BLUEBUBBLES_PASSWORD=your_bluebubbles_password
# BLUEBUBBLES_WEBHOOK_PORT=4000
# ALLOWED_IMESSAGE_HANDLES=+15551234567,handle@icloud.com


# ── Optional: MCP servers (external tools) ────────────────────

# Connect Kokoro as an MCP *client* to external Model Context Protocol servers;
# their tools are mounted into the conversational palette, namespaced
# `mcp_<server>_<tool>`. JSON array; unset/empty = no MCP tools. Each server is
# fail-open at connect time (an unreachable server is logged and skipped).
# Transports: "http"/"sse" (remote; { name, transport, url, headers? }) and
# "stdio" (local subprocess; { name, transport, command, args?, env?, cwd? }).
# `name` must be unique and match [a-zA-Z0-9_-]. MCP tools are NOT offered to
# read-only watcher ticks. See docs/ai-layer.md.
# MCP_SERVERS=[{"name":"kioku","transport":"http","url":"https://api.kioku.localhost/mcp"},{"name":"fs","transport":"stdio","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/srv/data"]}]


# ── Optional: Self-authored routines ──────────────────────────

# Mashiro can offer to save a just-completed task as a routine, and the weekly
# self-review pass can offer to refine/retire failing ones — always on,
# human-approved via tap-to-approve; never autonomous. COOLDOWN_DAYS is the base
# quiet window after a decline (escalates on repeat declines) so a "no" isn't
# re-offered for a while. See docs/ai-layer.md.
# ROUTINE_PROPOSAL_COOLDOWN_DAYS=14


# ── Optional: Kansoku observability ───────────────────────────

# Ship every log line (alongside stdout) to the workspace's Kansoku service.
# Both vars must be set together — either missing leaves the logger
# stdout-only (graceful in dev and during the Kansoku rollout window).
# Use the same KANSOKU_INGEST_TOKEN value across services; rotate by
# updating each .env and restarting.
# KANSOKU_URL=https://api.kansoku.localhost
# KANSOKU_INGEST_TOKEN=
