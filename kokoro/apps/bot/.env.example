# kokoro/bot — Generated by @kagami/env — edit src/env.ts and run `npm run env:gen`.

# === Telegram ===

# Telegram bot token (primary platform).
TELEGRAM_BOT_TOKEN=

# Comma-separated numeric Telegram user ids allowed to talk to the bot.
ALLOWED_USER_IDS=123456789,987654321

# === MongoDB ===

# MongoDB connection string.
MONGODB_URI=mongodb://localhost:27017/kokoro

# === Sibling services ===

# Kioku long-term memory service origin. Defaults to the Portless URL;
# use http://localhost:7777 only when running Kioku standalone (its
# bind-port fallback). The client is fail-open — chat continues degraded
# when Kioku is unreachable.
KIOKU_URL=https://api.kioku.localhost

# Kizuna CRM origin (context reads + confirmation-gated writes). Defaults
# to the Portless URL; use http://localhost:3000 only when running the
# Kizuna API standalone. CRM tools are always registered; reads/writes fail
# open if Kizuna is unreachable.
KIZUNA_URL=https://api.kizuna.localhost

# === LLM ===

# Chat inference kind — `native` is the only supported value for Kokoro
# chat (the @kagami/llm gateway with first-party provider SDKs).
LLM_KIND=native

# Chat provider: anthropic | openai | xai. The matching *_API_KEY is
# required (validated at bot startup).
LLM_PROVIDER=anthropic

# The Default model tier.
LLM_MODEL=claude-sonnet-4-6

# Optional Fast-tier override — unset = per-provider default (anthropic:
# claude-haiku-4-5). Used by getModel(Fast).
# LLM_MODEL_FAST=claude-haiku-4-5

# Optional Smart-tier override — unset = per-provider default (anthropic:
# claude-sonnet-4-6). Used by getModel(Smart).
# LLM_MODEL_SMART=claude-sonnet-4-6

# Per-attempt chat deadline (ms). The @kagami/llm gateway aborts and
# retries an attempt that exceeds this, so a slow/hung provider response
# fails over fast instead of eating the conversational turn budget. This is
# the per-attempt cap, NOT the turn budget — that's the per-call-site
# LLM_TIMEOUT_MS constants (generate.ts 120s, acknowledge.ts 60s,
# watcher/routine 180s).
LLM_ATTEMPT_TIMEOUT_MS=30000

# Anthropic API key — required when LLM_PROVIDER=anthropic (the default).
ANTHROPIC_API_KEY=

# OpenAI API key — required when LLM_PROVIDER=openai; also the fallback
# key for openai STT.
# OPENAI_API_KEY=

# xAI API key — required when LLM_PROVIDER=xai or IMAGE_GENERATION_MODEL
# uses the xai provider.
# XAI_API_KEY=

# Google AI Studio key — required when IMAGE_GENERATION_MODEL=google/…
# GOOGLE_API_KEY=

# === App ===

# IANA timezone; used for prompts, schedulers, and calendar formatting.
TIMEZONE=America/New_York

# Location of soul.md, instructions/*.md, and reference images.
CONTEXT_PATH=./context

# Pino log level.
LOG_LEVEL=info

# Runtime environment.
NODE_ENV=development

# === Image generation ===

# Image generation model, "provider/model" format. Provider keys are
# reused from the LLM section (so xai/* needs XAI_API_KEY, etc.). When
# unset, the sendPhoto tool is omitted from Kokoro's tool palette.
# IMAGE_GENERATION_MODEL=xai/grok-imagine-image

# === Voice ===

# Inbound speech-to-text, "provider/model" format — see docs/voice.md.
# Only the "openai" provider surface is supported; local whisper.cpp is
# just STT_BASE_URL pointing at the local OpenAI-compatible server.
# STT_PROVIDER=openai/whisper-1

# STT endpoint override for local whisper.cpp (OpenAI-compatible
# /v1/audio/transcriptions).
# STT_BASE_URL=http://127.0.0.1:8089/v1

# STT API key. Any non-empty string works for whisper.cpp servers that
# don't enforce auth; unset falls back to OPENAI_API_KEY.
# STT_API_KEY=

# Outbound text-to-speech (sendVoice tool), "provider/model" format.
# Requires TTS_VOICE_ID, and the provider's key (elevenlabs →
# ELEVENLABS_API_KEY).
# TTS_PROVIDER=elevenlabs/eleven_v3

# Voice id for the configured TTS provider.
# TTS_VOICE_ID=

# ElevenLabs API key — required when TTS_PROVIDER uses elevenlabs.
# ELEVENLABS_API_KEY=

# === Kao (Google identity) ===

# Kao identity service origin; short-lived Google access tokens are vended
# from ${KAO_URL}/grants/<consumer>/token. Set together with KAO_TOKEN.
# KAO_URL=https://api.kao.localhost

# Bearer presented to Kao's /grants/* vend surface (≥16 chars).
# KAO_TOKEN=

# === Web search ===

# Brave Search API key (free tier: 2000 queries/month, 1 query/sec —
# https://brave.com/search/api/). When set, the LLM gets a fast no-browser
# webSearch tool and the in-browser `search` action is dropped from the
# browse tool.
# BRAVE_SEARCH_API_KEY=

# === Browser tool ===

# Browser tool mode: local (Playwright Chromium) | cloud (Browserbase).
# The browser tool is always on; cloud mode requires the Browserbase
# credentials below.
BROWSER_ENV=local

# Browserbase API key — required when BROWSER_ENV=cloud.
# BROWSERBASE_API_KEY=

# Browserbase project id — required when BROWSER_ENV=cloud.
# BROWSERBASE_PROJECT_ID=

# Model override for the browser-driving agent.
# BROWSER_MODEL=anthropic/claude-haiku-4-5

# lat,lng for emulated geolocation.
# BROWSER_GEOLOCATION=40.7128,-74.0060

# Persistent browser profile directory (local mode).
BROWSER_DATA_DIR=./data/browser

# Headless browser toggle — only the literal "true" is truthy.
BROWSER_HEADLESS=true

# === Sandboxed code execution ===

# executeCode tool: runs LLM-written Python/Node scripts in a locked-down
# ephemeral Docker container (no network, empty env, read-only rootfs,
# memory/CPU/pid caps — see apps/bot/src/services/code-sandbox.ts).
# Requires a local Docker daemon at runtime; the tool fails open per call
# when the daemon is down. Every run is tap-to-approve and the bubble shows
# the full code. Only the literal "true" enables — "false", empty, and
# unset all leave the tool off (the emergency off switch works without
# deleting the var).
EXECUTE_CODE_ENABLED=false

# Docker image for Python runs.
EXECUTE_CODE_PYTHON_IMAGE=python:3.12-slim

# Docker image for Node runs.
EXECUTE_CODE_NODE_IMAGE=node:22-slim

# Wall-clock cap per sandboxed run (ms).
EXECUTE_CODE_TIMEOUT_MS=120000

# Hard memory cap per run (swap pinned to the same value).
EXECUTE_CODE_MEMORY_MB=512

# === Location awareness ===

# Optional geocoding key for location awareness — without it, geocoding
# degrades to raw coordinates (reverseGeocode returns null); never a hard
# requirement.
# GOOGLE_MAPS_API_KEY=

# Movement distance (meters) that counts as a location change.
LOCATION_MOVEMENT_THRESHOLD_M=100

# Quiet delay (ms) before proactive location-triggered engagement.
LOCATION_PROACTIVE_DELAY_MS=1200000

# Max age (hours) of a location fix still injected into context.
LOCATION_CONTEXT_MAX_AGE_H=12

# Distinct visits before an unlabeled spot is proposed as a learned place.
PLACE_LEARNING_VISITS=3

# Clustering radius (meters) for place learning.
PLACE_LEARNING_RADIUS_M=200

# Sliding window (days) for counting place-learning visits.
PLACE_LEARNING_WINDOW_DAYS=30

# === iMessage (BlueBubbles) ===

# BlueBubbles server URL for the iMessage adapter — see docs/imessage.md.
# Telegram and iMessage can run side-by-side.
# BLUEBUBBLES_HOST=http://192.168.1.10:1234

# BlueBubbles password; authenticates both outbound API calls and inbound
# webhook posts.
# BLUEBUBBLES_PASSWORD=

# Local port the BlueBubbles webhook listener binds.
BLUEBUBBLES_WEBHOOK_PORT=4000

# Comma-separated iMessage handles (phone numbers / iCloud emails)
# allowed to talk to the bot. Non-empty requires BLUEBUBBLES_HOST.
ALLOWED_IMESSAGE_HANDLES=

# === MCP servers ===

# External MCP servers Kokoro connects to as a client; their tools are
# mounted into the conversational palette, namespaced `mcp_<server>_<tool>`.
# JSON array; unset/empty = no MCP tools. Each server is fail-open at
# connect time (an unreachable server is logged and skipped). Transports:
# "http"/"sse" (remote; { name, transport, url, headers? }) and "stdio"
# (local subprocess; { name, transport, command, args?, env?, cwd? }).
# `name` must be unique and match [a-zA-Z0-9_-]. MCP tools are NOT offered
# to read-only watcher ticks. See docs/ai-layer.md.
MCP_SERVERS=

# === Self-authored routines ===

# Base quiet window (days) after a declined routine/skill proposal
# (escalates on repeat declines) so a "no" isn't re-offered for a while.
# Proposals are always human-approved via tap-to-approve; never autonomous.
# See docs/ai-layer.md.
ROUTINE_PROPOSAL_COOLDOWN_DAYS=14

# === Kansoku (observability) ===

# Ship every log line to the workspace's Kansoku service alongside stdout.
# Both Kansoku vars must be set together — either missing leaves the logger
# stdout-only (fail-open; observability failure never wedges this service).
# KANSOKU_URL=https://api.kansoku.localhost

# Shared HMAC token the Kansoku ingest surface requires.
# KANSOKU_INGEST_TOKEN=
