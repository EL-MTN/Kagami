{
  "name": "@kokoro/bot",
  "private": true,
  "type": "module",
  "portless": "bot.kokoro",
  "scripts": {
    "dev": "portless run tsx watch src/index.ts",
    "build": "tsx build.ts",
    "start": "node dist/index.js",
    "test": "vitest run --project bot",
    "test:watch": "vitest --project bot",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix"
  },
  "dependencies": {
    "@ai-sdk/elevenlabs": "^2.0.0",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/xai": "^3.0.67",
    "@browserbasehq/stagehand": "^3.0.0",
    "@kagami/llm": "*",
    "@kokoro/db": "*",
    "@kokoro/kizuna": "*",
    "@kokoro/memory": "*",
    "@kokoro/shared": "*",
    "ai": "^6.0.175",
    "date-fns": "^4.1.0",
    "googleapis": "^171.4.0",
    "grammy": "^1.42.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@kagami/eslint-config": "*",
    "@kagami/tsconfig": "*",
    "@types/node": "^22.10.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
