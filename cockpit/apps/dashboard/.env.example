# cockpit/dashboard — Generated by @kagami/env — edit src/env.ts and run `npm run env:gen`.

# === Service endpoints ===

# Kioku memory API origin. Probed for /health and /facts/count.
KIOKU_API_URL=https://api.kioku.localhost

# Kokoro dashboard origin. Cockpit reads /api/ops/summary for pending
# approvals and failed routines/watchers (the bot itself has no HTTP surface).
KOKORO_DASHBOARD_URL=https://kokoro.localhost

# Kizuna CRM API origin. Probed for /health, /oauth/google/status, and the
# Gmail/Calendar sync states.
KIZUNA_API_URL=https://api.kizuna.localhost

# Kansoku observability API origin. Probed for /health and open error groups.
KANSOKU_API_URL=https://api.kansoku.localhost

# Kao identity API origin. Probed for /health; grant status additionally
# needs KAO_TOKEN.
KAO_API_URL=https://api.kao.localhost

# === Kao (Google identity) ===

# Bearer for Kao's /grants read surface — lets the Kao card show per-grant
# status. Checked only at render: missing (or shorter than Kao's 16-char
# floor) degrades to a "grant visibility not configured" warning card;
# Cockpit never fails closed over it.
# KAO_TOKEN=
