{
  "name": "mashiro",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "seed:vault": "tsx scripts/seed-vault.ts",
    "auth:google": "tsx scripts/authorize-google.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.0",
    "@ai-sdk/google": "^3.0.30",
    "@ai-sdk/openai": "^1.2.0",
    "@ai-sdk/xai": "^1.2.18",
    "ai": "^4.3.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.0",
    "googleapis": "^171.4.0",
    "grammy": "^1.30.0",
    "gray-matter": "^4.0.3",
    "mongoose": "^8.9.0",
    "pino": "^9.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.0"
  }
}
