{
  "name": "kizuna",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "npm@11.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "dev:api": "turbo run dev --filter=@kizuna/api",
    "dev:dashboard": "turbo run dev --filter=@kizuna/dashboard"
  },
  "devDependencies": {
    "portless": "^0.12.0",
    "turbo": "^2.8.15"
  }
}
