{
  "name": "kagami",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "kioku/apps/*",
    "kioku/packages/*",
    "kokoro/apps/*",
    "kokoro/packages/*",
    "kizuna/apps/*",
    "kizuna/packages/*",
    "kansoku/apps/*",
    "kansoku/packages/*",
    "kao/apps/*",
    "kao/packages/*",
    "cockpit/apps/*",
    "cockpit/packages/*",
    "shared/packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "./dev-all.sh",
    "kioku:dev": "turbo run dev --filter=\"@kioku/*\"",
    "kokoro:dev": "turbo run dev --filter=\"@kokoro/*\"",
    "kizuna:dev": "turbo run dev --filter=\"@kizuna/*\"",
    "kioku:dev:api": "turbo run dev --filter=@kioku/api",
    "kioku:dev:dashboard": "turbo run dev --filter=@kioku/dashboard",
    "kokoro:dev:bot": "turbo run dev --filter=@kokoro/bot",
    "kokoro:dev:dashboard": "turbo run dev --filter=@kokoro/dashboard",
    "kizuna:dev:api": "turbo run dev --filter=@kizuna/api",
    "kizuna:dev:dashboard": "turbo run dev --filter=@kizuna/dashboard",
    "kansoku:dev": "turbo run dev --filter=\"@kansoku/*\"",
    "kansoku:dev:api": "turbo run dev --filter=@kansoku/api",
    "kansoku:dev:dashboard": "turbo run dev --filter=@kansoku/dashboard",
    "kansoku:debug": "tsx kansoku/apps/api/scripts/kansoku-debug.ts",
    "kao:dev": "turbo run dev --filter=\"@kao/*\"",
    "kao:dev:api": "turbo run dev --filter=@kao/api",
    "kao:dev:dashboard": "turbo run dev --filter=@kao/dashboard",
    "cockpit:dev": "turbo run dev --filter=\"@cockpit/*\"",
    "cockpit:dev:dashboard": "turbo run dev --filter=@cockpit/dashboard",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "env:gen": "turbo run build --filter=@kagami/env --output-logs=errors-only && tsx scripts/env/generate.ts",
    "env:check": "turbo run build --filter=@kagami/env --output-logs=errors-only && tsx scripts/env/generate.ts --check",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/apps/**/src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/packages/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/apps/**/{tests,scripts}/**/*.{ts,tsx}": [
      "prettier --write"
    ],
    "**/scripts/**/*.ts": [
      "prettier --write"
    ],
    "**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "knip": "^5.0.0",
    "lint-staged": "^17.0.5",
    "msw": "^2.10.4",
    "portless": "^0.12.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.15",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
