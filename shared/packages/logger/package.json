{
  "name": "@kagami/logger",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./kansoku-stream": {
      "types": "./dist/kansoku-stream.d.ts",
      "default": "./dist/kansoku-stream.js"
    },
    "./trace": {
      "types": "./dist/trace.d.ts",
      "default": "./dist/trace.js"
    },
    "./express-trace": {
      "types": "./dist/express-trace.d.ts",
      "default": "./dist/express-trace.js"
    },
    "./traced-fetch": {
      "types": "./dist/traced-fetch.d.ts",
      "default": "./dist/traced-fetch.js"
    }
  },
  "scripts": {
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@kagami/eslint-config": "*",
    "@kagami/tsconfig": "*",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "eslint": "^10.3.0",
    "express": "^5.2.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
