{
  "name": "@kagami/env",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix"
  },
  "dependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@kagami/eslint-config": "*",
    "@kagami/tsconfig": "*",
    "@types/node": "^22.10.0",
    "eslint": "^10.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
