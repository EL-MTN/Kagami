# HTTP server bind address. Under `portless run`, PORT is injected automatically;
# the 7777 fallback only applies when running standalone (e.g. `tsx src/server.ts`).
# KIOKU_HOST=127.0.0.1
# PORT=7777

# Pino log level. Defaults to 'info'. Use 'debug' for request-level detail.
# LOG_LEVEL=info

# === Kansoku (observability) ===
# Ship every log line to the workspace's Kansoku service alongside stdout.
# Both vars must be set together — either missing leaves the logger
# stdout-only (graceful in dev and during the Kansoku rollout window).
# Generate KANSOKU_INGEST_TOKEN with `openssl rand -hex 32` and use the
# same value across every sibling and Kansoku's own .env. Rotation is a
# manual env edit + restart on each service.
# KANSOKU_URL=https://api.kansoku.localhost
# KANSOKU_INGEST_TOKEN=

# === MongoDB ===
# Connection URI for the storage layer. Include the DB name in the path —
# mongo.ts reads it from there (and falls back to "kioku" if the URI's
# default DB is "test"). Defaults to a local atlas-local replica set on
# 127.0.0.1:27017. Boot it with:
#   atlas local start mongodb
# (or `docker run -p 27017:27017 mongodb/mongodb-atlas-local`).
# MONGODB_URI=mongodb://127.0.0.1:27017/kioku?directConnection=true
# Vector index dim is probed from the embedding provider at startup.

# === Ingest rate limits ===
# Per-IP caps for embedding-heavy write endpoints, over a one-minute window.
# KIOKU_BULK_RATE_LIMIT_PER_MIN=10
# KIOKU_SESSION_RATE_LIMIT_PER_MIN=5

# === BM25 sigmoid tuning ===
# Optional overrides for query-length buckets used to normalize raw Atlas Search
# BM25 scores. Defaults are documented in docs/retrieval.md.
# BM25_SIGMOID_MIDPOINT_3=1.5
# BM25_SIGMOID_STEEPNESS_3=1.5
# BM25_SIGMOID_MIDPOINT_6=2.0
# BM25_SIGMOID_STEEPNESS_6=1.0
# BM25_SIGMOID_MIDPOINT_9=2.5
# BM25_SIGMOID_STEEPNESS_9=1.2
# BM25_SIGMOID_MIDPOINT_15=3.0
# BM25_SIGMOID_STEEPNESS_15=1.0
# BM25_SIGMOID_MIDPOINT_GT15=3.5
# BM25_SIGMOID_STEEPNESS_GT15=1.0

# === LLM (chat / answerer) ===
# Provider profile. Picks URL+key defaults: 'lmstudio' (default) or 'openai'.
LLM_PROVIDER=lmstudio
# Override URL/key if your endpoint isn't the profile default.
# LLM_URL=http://localhost:1234/v1
# LLM_API_KEY=lm-studio
MODEL=

# === Embeddings ===
# Independent provider for embeddings. Same profiles as LLM_PROVIDER.
# Common pattern: chat=openai (gpt-4o-mini), embeddings=lmstudio (local nomic).
EMBEDDING_PROVIDER=lmstudio
# EMBEDDING_URL=http://localhost:1234/v1
# EMBEDDING_API_KEY=lm-studio
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5

# Used as the default LLM_API_KEY / EMBEDDING_API_KEY when the corresponding
# *_PROVIDER is 'openai' and you haven't set an explicit override.
# OPENAI_API_KEY=
