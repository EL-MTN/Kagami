# kioku/api — Generated by @kagami/env — edit src/env.ts and run `npm run env:gen`.

# === Standalone fallback ===

# Standalone fallback bind host. Under `portless run`, PORT is injected
# automatically and https://api.kioku.localhost is proxied; these only
# matter running standalone (e.g. `tsx src/server.ts`).
KIOKU_HOST=127.0.0.1

# Standalone fallback bind port (Portless injects its own otherwise).
PORT=7777

# === Logging ===

# Pino log level (`silent` in tests).
LOG_LEVEL=info

# === Kansoku (observability) ===

# Ship every log line to the workspace's Kansoku service alongside stdout.
# Both Kansoku vars must be set together — either missing leaves the logger
# stdout-only (fail-open; observability failure never wedges this service).
# An invalid URL likewise warns and disables the shipper instead of failing
# boot.
# KANSOKU_URL=https://api.kansoku.localhost

# Shared HMAC token the Kansoku ingest surface requires.
# KANSOKU_INGEST_TOKEN=

# === MongoDB ===

# Connection URI for the storage layer. Include the DB name in the path —
# mongo.ts reads it from there (and falls back to "kioku" if the URI's
# default DB is "test"). Defaults to a local atlas-local replica set on
# 127.0.0.1:27017 ($vectorSearch/$search need atlas-local, not vanilla
# Mongo). Boot it with:
#   atlas local start mongodb
# (or `docker run -p 27017:27017 mongodb/mongodb-atlas-local`).
# The vector index dim is probed from the embedding provider at startup.
# A malformed URI fails boot — only an UNSET value uses the local default
# (a data pointer must never silently redirect to a different database).
MONGODB_URI=mongodb://127.0.0.1:27017/kioku?directConnection=true

# === Retrieval ===

# Number of candidate facts the answerer pulls per query before ranking.
KIOKU_TOP_K=50

# Operator timezone (IANA name) for day-granular `event_date` stamping —
# localToday()/sessionDateOf() in src/dates.ts resolve calendar days in
# this zone. Unset ⇒ the process timezone, which is correct on a personal
# machine but WRONG on a UTC server: evening conversations would be
# stamped tomorrow, corrupting the answerer's newest-wins ordering. Set
# this when deploying anywhere whose clock zone differs from the
# operator's.
# KIOKU_TIMEZONE=America/Los_Angeles

# === Ingest rate limits ===

# Per-IP cap on POST /facts/bulk (embedding-heavy ingest), over a
# one-minute window. Resolved at boot by routes/rate-limit.ts (throws on a
# non-positive-integer override).
KIOKU_BULK_RATE_LIMIT_PER_MIN=10

# Per-IP cap on POST /sessions, over a one-minute window. Resolved at boot
# by routes/rate-limit.ts (throws on a non-positive-integer override).
KIOKU_SESSION_RATE_LIMIT_PER_MIN=5

# === Consolidation (maintenance cron) ===

# Enable the in-process periodic consolidation cron: a durable-only
# entity-grouped curation pass (DROPS episodic chat-exhaust, MERGES
# fragmented episodes — see prompts/consolidate.md) that runs to convergence
# over the default scope on a timer. Mutations are journaled in `history`
# (actor "consolidate-cron"); there is no undo beyond that journal. Only the
# literal "true" enables — "false", empty, and unset all leave it OFF (the
# off switch works without deleting the var). When enabled, also serves a
# guarded POST /consolidate for a manual run.
KIOKU_CONSOLIDATE_ENABLED=false

# Hours between consolidation cron passes (fractional allowed for testing).
# The first pass fires one interval after boot, never at startup. Ignored
# when KIOKU_CONSOLIDATE_ENABLED is off.
KIOKU_CONSOLIDATE_INTERVAL_HOURS=24

# Editor model for the consolidation cron, overriding LLM_MODEL for that
# pass only (the answerer keeps LLM_MODEL). The durable-only merge/drop
# judgments need a strong editor — gpt-4.1 is the validated choice; a small
# model like gpt-4o-mini breaks merge atomicity. Unset ⇒ reuse LLM_MODEL.
# KIOKU_CONSOLIDATE_MODEL=gpt-4.1

# === BM25 sigmoid tuning ===

# Optional midpoint override for the ≤3-term query-length bucket of
# the BM25 sigmoid normalizer. Defaults are the calibrated constants in
# retrieval/scoring.ts — refit via scripts/probe-bm25-scores.ts (see
# docs/retrieval.md and docs/bench.md).
# BM25_SIGMOID_MIDPOINT_3=

# Optional steepness override for the ≤3-term query-length bucket of
# the BM25 sigmoid normalizer. Defaults are the calibrated constants in
# retrieval/scoring.ts — refit via scripts/probe-bm25-scores.ts (see
# docs/retrieval.md and docs/bench.md).
# BM25_SIGMOID_STEEPNESS_3=

# Optional midpoint override for the ≤6-term query-length bucket of
# the BM25 sigmoid normalizer. Defaults are the calibrated constants in
# retrieval/scoring.ts — refit via scripts/probe-bm25-scores.ts (see
# docs/retrieval.md and docs/bench.md).
# BM25_SIGMOID_MIDPOINT_6=

# Optional steepness override for the ≤6-term query-length bucket of
# the BM25 sigmoid normalizer. Defaults are the calibrated constants in
# retrieval/scoring.ts — refit via scripts/probe-bm25-scores.ts (see
# docs/retrieval.md and docs/bench.md).
# BM25_SIGMOID_STEEPNESS_6=

# Optional midpoint override for the ≤9-term query-length bucket of
# the BM25 sigmoid normalizer. Defaults are the calibrated constants in
# retrieval/scoring.ts — refit via scripts/probe-bm25-scores.ts (see
# docs/retrieval.md and docs/bench.md).
# BM25_SIGMOID_MIDPOINT_9=

# Optional steepness override for the ≤9-term query-length bucket of
# the BM25 sigmoid normalizer. Defaults are the calibrated constants in
# retrieval/scoring.ts — refit via scripts/probe-bm25-scores.ts (see
# docs/retrieval.md and docs/bench.md).
# BM25_SIGMOID_STEEPNESS_9=

# Optional midpoint override for the ≤15-term query-length bucket of
# the BM25 sigmoid normalizer. Defaults are the calibrated constants in
# retrieval/scoring.ts — refit via scripts/probe-bm25-scores.ts (see
# docs/retrieval.md and docs/bench.md).
# BM25_SIGMOID_MIDPOINT_15=

# Optional steepness override for the ≤15-term query-length bucket of
# the BM25 sigmoid normalizer. Defaults are the calibrated constants in
# retrieval/scoring.ts — refit via scripts/probe-bm25-scores.ts (see
# docs/retrieval.md and docs/bench.md).
# BM25_SIGMOID_STEEPNESS_15=

# Optional midpoint override for the >15-term query-length bucket of
# the BM25 sigmoid normalizer. Defaults are the calibrated constants in
# retrieval/scoring.ts — refit via scripts/probe-bm25-scores.ts (see
# docs/retrieval.md and docs/bench.md).
# BM25_SIGMOID_MIDPOINT_GT15=

# Optional steepness override for the >15-term query-length bucket of
# the BM25 sigmoid normalizer. Defaults are the calibrated constants in
# retrieval/scoring.ts — refit via scripts/probe-bm25-scores.ts (see
# docs/retrieval.md and docs/bench.md).
# BM25_SIGMOID_STEEPNESS_GT15=

# === LLM (chat / answerer) ===

# Chat/answerer provider kind. Kioku goes through the @kagami/llm gateway
# and is openai-compatible only — the deployed default is OpenAI; LM Studio
# (local), vLLM, and Ollama are drop-in alternatives.
LLM_KIND=openai-compatible

# Chat endpoint base URL. Unset boots with a warning and fails at first
# request — set it (e.g. https://api.openai.com/v1, or
# http://localhost:1234/v1 for LM Studio).
LLM_BASE_URL=https://api.openai.com/v1

# Chat endpoint API key (any non-empty string works for local servers like
# LM Studio).
LLM_API_KEY=

# Chat model id, provider-native — gpt-4o-mini, or whatever your local
# server exposes. Unset boots with a warning.
LLM_MODEL=gpt-4o-mini

# Optional per-attempt gateway deadline in milliseconds. Must be a positive
# finite number within Node's timer ceiling (2147483647); anything else is
# ignored with a warn — an out-of-range value would otherwise make
# AbortSignal.timeout() throw on every call. Coerced with Number(), not
# parseInt, so suffixed junk like "180s" is rejected rather than
# partial-parsed.
# LLM_TIMEOUT_MS=

# === Embeddings ===

# Embedding provider kind — openai-compatible only, same as LLM_KIND.
# Chat and embedding endpoints are independent; set each separately.
EMBEDDING_KIND=openai-compatible

# Embedding endpoint base URL. Unset boots with a warning and fails at
# first request.
EMBEDDING_BASE_URL=https://api.openai.com/v1

# Embedding endpoint API key.
EMBEDDING_API_KEY=

# Embedding model id. The deployed default is OpenAI
# text-embedding-3-small (1536-dim); the vector-index dim is probed from
# the provider at startup, so a model swap requires dropping the vector
# indexes and re-ingesting (see docs/configuration.md).
EMBEDDING_MODEL=text-embedding-3-small

# MODEL is a legacy alias for LLM_MODEL (used when LLM_MODEL is unset).
