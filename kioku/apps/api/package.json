{
  "name": "@kioku/api",
  "version": "0.1.0",
  "description": "Personal long-term memory subsystem for an agentic assistant.",
  "private": true,
  "type": "module",
  "portless": "api.kioku",
  "scripts": {
    "dev": "portless run tsx watch src/server.ts",
    "start": "node --import tsx src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/ scripts/",
    "lint:fix": "eslint src/ tests/ scripts/ --fix"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.46",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.175",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "mongodb": "^7.2.0",
    "openai": "^6.0.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@kagami/eslint-config": "*",
    "@kagami/tsconfig": "*",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "mongodb-memory-server": "^11.1.0",
    "pino-pretty": "^13.1.3",
    "portless": "^0.12.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  }
}
