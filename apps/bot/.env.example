# ─────────────────────────────────────────────────────────────
# Mashiro bot — copy to apps/bot/.env and fill in.
# Anything left commented falls back to the default in
# packages/shared/src/config.ts. Validation runs at startup.
# ─────────────────────────────────────────────────────────────


# ── Required ──────────────────────────────────────────────────

# Telegram (primary platform)
TELEGRAM_BOT_TOKEN=your_bot_token_here
ALLOWED_USER_IDS=123456789,987654321

# MongoDB
MONGODB_URI=mongodb://localhost:27017/mashiro

# LLM
LLM_PROVIDER=anthropic                 # anthropic | openai | xai
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENAI_API_KEY=your_openai_key_here  # required when LLM_PROVIDER=openai
# XAI_API_KEY=your_xai_key_here        # required when LLM_PROVIDER=xai

# Embeddings (Memory Engine) — see docs/memory-management.md
GOOGLE_API_KEY=your_google_ai_studio_key_here
# EMBEDDING_PROVIDER=google            # only "google" supported today
# EMBEDDING_MODEL=gemini-embedding-001


# ── App ───────────────────────────────────────────────────────

LOG_LEVEL=info                         # fatal | error | warn | info | debug | trace
NODE_ENV=development                   # development | production | test
# TIMEZONE=America/New_York            # IANA tz; used for prompts, schedulers, calendar formatting
# CONTEXT_PATH=./context               # location of soul.md and reference images


# ── Optional: image generation ────────────────────────────────

# Format: "provider/model". Provider keys are reused from the LLM section
# (so xai/* needs XAI_API_KEY above, etc.). When unset, the sendPhoto tool
# is omitted from Mashiro's tool palette.
# IMAGE_GENERATION_MODEL=xai/grok-imagine-image


# ── Optional: voice ───────────────────────────────────────────

# Inbound speech-to-text — see docs/voice.md
# Local whisper.cpp (default mode): point STT_BASE_URL at the local
# OpenAI-compatible server. STT_API_KEY can be any non-empty string for
# whisper.cpp servers that don't enforce auth.
# STT_PROVIDER=openai/whisper-1
# STT_BASE_URL=http://127.0.0.1:8089/v1
# STT_API_KEY=local

# Outbound text-to-speech — sendVoice tool
# TTS_PROVIDER=elevenlabs/eleven_v3
# TTS_VOICE_ID=your_elevenlabs_voice_id_here
# ELEVENLABS_API_KEY=your_elevenlabs_api_key_here


# ── Optional: Google OAuth (email + calendar + reminders) ─────

# Run `npm run auth:google` to obtain a refresh token. All three values
# must be set together once any one of them is set.
# GOOGLE_OAUTH_CLIENT_ID=your_client_id_here
# GOOGLE_OAUTH_CLIENT_SECRET=your_client_secret_here
# GOOGLE_OAUTH_REFRESH_TOKEN=your_refresh_token_here


# ── Optional: web search ──────────────────────────────────────
# Brave Search API. Free tier: 2000 queries/month, 1 query/sec.
# When set, the LLM gets a fast no-browser webSearch tool and the
# in-browser `search` action is dropped from the browse tool.
# https://brave.com/search/api/
# BRAVE_SEARCH_API_KEY=your_brave_api_key_here

# ── Optional: browser tool ────────────────────────────────────

BROWSER_ENABLED=false
# BROWSER_ENV=local                    # local (Playwright Chromium) | cloud (Browserbase)
# BROWSER_MODEL=anthropic/claude-haiku-4-5
# BROWSER_GEOLOCATION=40.7128,-74.0060 # lat,lng for emulated geolocation
# BROWSER_HEADLESS=true
# BROWSER_DATA_DIR=./data/browser
# BROWSERBASE_API_KEY=your_browserbase_api_key_here       # required when BROWSER_ENV=cloud
# BROWSERBASE_PROJECT_ID=your_browserbase_project_id_here


# ── Optional: location awareness ──────────────────────────────

LOCATION_ENABLED=false
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here       # required when LOCATION_ENABLED=true
# LOCATION_MOVEMENT_THRESHOLD_M=100
# LOCATION_PROACTIVE_DELAY_MS=1200000
# LOCATION_CONTEXT_MAX_AGE_H=12


# ── Optional: iMessage adapter via BlueBubbles ────────────────

# See docs/imessage.md. Telegram and iMessage can run side-by-side.
# BLUEBUBBLES_HOST sets the BlueBubbles server URL; password authenticates
# both outbound API calls and inbound webhook posts.
# BLUEBUBBLES_HOST=http://192.168.1.10:1234
# BLUEBUBBLES_PASSWORD=your_bluebubbles_password
# BLUEBUBBLES_WEBHOOK_PORT=4000
# ALLOWED_IMESSAGE_HANDLES=+15551234567,handle@icloud.com
