# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
ALLOWED_USER_IDS=123456789,987654321

# LLM
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
LLM_MODEL=claude-sonnet-4-6

# Image Generation
XAI_API_KEY=your_xai_api_key_here

# Embeddings (Memory Engine)
GOOGLE_API_KEY=your_google_ai_studio_key_here
# EMBEDDING_PROVIDER=google
# EMBEDDING_MODEL=gemini-embedding-001

# Google OAuth (optional — enables email, calendar, reminders)
# Run `npm run auth:google` to get the refresh token
GOOGLE_OAUTH_CLIENT_ID=your_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_client_secret_here
GOOGLE_OAUTH_REFRESH_TOKEN=your_refresh_token_here

# Location Awareness (optional — enables location sharing processing)
LOCATION_ENABLED=false
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# LOCATION_MOVEMENT_THRESHOLD_M=100
# LOCATION_PROACTIVE_DELAY_MS=1200000
# LOCATION_CONTEXT_MAX_AGE_H=12

# TTS / Voice Messages (optional — enables sendVoice tool)
# TTS_PROVIDER=elevenlabs/eleven_v3
# TTS_VOICE_ID=your_elevenlabs_voice_id_here
# ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Browser (optional — enables web browsing tool)
# BROWSER_ENV=local  → runs Chromium locally (run `npx playwright install chromium`)
# BROWSER_ENV=cloud  → uses Browserbase (requires API key + project ID)
BROWSER_ENABLED=false
BROWSER_ENV=local
# BROWSERBASE_API_KEY=your_browserbase_api_key_here
# BROWSERBASE_PROJECT_ID=your_browserbase_project_id_here
BROWSER_MODEL=anthropic/claude-haiku-4-5
BROWSER_GEOLOCATION=40.7128,-74.0060
BROWSER_DATA_DIR=./data/browser
BROWSER_HEADLESS=true

# MongoDB
MONGODB_URI=mongodb://localhost:27017/mashiro

# App
LOG_LEVEL=info
NODE_ENV=development
