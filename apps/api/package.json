{
  "name": "@kizuna/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "src/main.ts",
  "portless": "api.kizuna",
  "scripts": {
    "dev": "portless run tsx watch src/main.ts",
    "build": "tsc -p .",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "smoke": "LOG_LEVEL=silent tsx scripts/smoke.ts",
    "smoke:dashboard": "LOG_LEVEL=silent tsx scripts/dashboard-smoke.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^5.0.1",
    "google-auth-library": "^9.15.0",
    "mongoose": "^8.8.0",
    "pino": "^9.5.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/supertest": "^6.0.2",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.0.0",
    "testcontainers": "^10.13.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.5"
  }
}
