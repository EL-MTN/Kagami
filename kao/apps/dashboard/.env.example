# Where the dashboard's Next.js server reaches the Kao API. Default works under
# Portless. Override only when both sides see the same hostname (e.g. CI).
KAO_API_URL=https://api.kao.localhost

# Bearer presented to /grants/*. Must match the API's KAO_TOKEN. The dashboard
# runs every /grants/* call server-side, so this never reaches the browser —
# Server Components and Server Actions inject Authorization for you.
KAO_TOKEN=replace-me-with-the-bearer-the-api-uses
