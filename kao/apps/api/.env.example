# kao/api — Generated by @kagami/env — edit src/env.ts and run `npm run env:gen`.

# MongoDB connection (`mongodb://` or `mongodb+srv://`).
MONGODB_URI=mongodb://127.0.0.1:27017/kao

# Database name.
KAO_DB_NAME=kao

# Single Google Cloud OAuth client (Web application type). Register exactly
# one authorized redirect URI: ${KAO_PUBLIC_URL}/oauth/callback.
# Kao's whole purpose is OAuth — these are required, not optional.
GOOGLE_OAUTH_CLIENT_ID=

# Google OAuth client secret.
GOOGLE_OAUTH_CLIENT_SECRET=

# Public origin Google redirects back to. The callback path is fixed at
# /oauth/callback; the grant being authorized is carried in signed state,
# so only this one redirect URI needs registering in Google Cloud.
KAO_PUBLIC_URL=https://api.kao.localhost

# Where the operator's browser lands after consent succeeds. Distinct from
# KAO_PUBLIC_URL because the dashboard runs on a separate Portless name
# (kao.localhost vs api.kao.localhost). The OAuth success page links here.
KAO_DASHBOARD_URL=https://kao.localhost

# Refresh tokens are AES-256-GCM encrypted at rest under this key.
# Generate once with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
KAO_ENCRYPTION_KEY=

# Bearer that sibling services must present to read /grants/* (token vend).
# Kao holds the crown-jewel credential WITH send/write scopes, so unlike the
# other services' open-at-localhost resource routes, the vend surface is
# always bearer-gated. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KAO_TOKEN=

# === Standalone fallback ===

# Standalone fallback bind host. Portless injects PORT and proxies
# https://api.kao.localhost; these only matter running outside Portless.
KAO_HOST=127.0.0.1

# Standalone fallback bind port (Portless injects its own otherwise).
PORT=4040

# === Logging ===

# Pino log level (`silent` in tests).
LOG_LEVEL=info

# === Kansoku (observability) ===

# Ship every log line to the workspace's Kansoku service alongside stdout.
# Both Kansoku vars must be set together — either missing leaves the logger
# stdout-only (fail-open; observability failure never wedges this service).
# An invalid URL likewise warns and disables the shipper instead of failing
# boot.
# KANSOKU_URL=https://api.kansoku.localhost

# Shared HMAC token the Kansoku ingest surface requires.
# KANSOKU_INGEST_TOKEN=
