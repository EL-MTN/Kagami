{
  "name": "@kao/api",
  "private": true,
  "type": "module",
  "portless": "api.kao",
  "scripts": {
    "dev": "portless run tsx watch src/main.ts",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix"
  },
  "dependencies": {
    "@kagami/env": "*",
    "@kagami/logger": "*",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "mongodb": "^7.2.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@kagami/eslint-config": "*",
    "@kagami/tsconfig": "*",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.3.0",
    "mongodb-memory-server": "^11.1.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
