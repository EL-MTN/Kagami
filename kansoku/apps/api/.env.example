# HTTP server bind address. Under `portless run`, PORT is injected automatically;
# the 7779 fallback only applies when running standalone (e.g. `tsx src/server.ts`).
# KANSOKU_HOST=127.0.0.1
# PORT=7779

# Pino log level. Defaults to 'info'. Use 'debug' for request-level detail.
# LOG_LEVEL=info

# === MongoDB ===
# Connection URI for the storage layer. Include the DB name in the path —
# mongo.ts reads it from there (and falls back to "kansoku" if the URI's
# default DB is "test"). Defaults to a local atlas-local replica set on
# 127.0.0.1:27017. Boot it with:
#   atlas local start mongodb
# (or `docker run -p 27017:27017 mongodb/mongodb-atlas-local`).
# Time-series collections require MongoDB 5.0+.
# MONGODB_URI=mongodb://127.0.0.1:27017/kansoku?directConnection=true

# === Ingest auth ===
# Shared HMAC token presented by sibling shippers in the `x-kansoku-auth`
# header. Generate one with `openssl rand -hex 32` and copy the same value
# into each sibling service's KANSOKU_INGEST_TOKEN. Rotation is a manual
# env-change-and-restart across the workspace.
#
# When unset, POST /v1/logs returns 503 fail-closed — the service won't
# silently accept unauthenticated ingest.
KANSOKU_INGEST_TOKEN=

# === Retention ===
# Time-series TTL for the `logs` collection, in days. The server reconciles
# this with `collMod` on every startup, so changing the value and restarting
# takes effect without manual ops. Defaults to 30; capped at 365 (longer
# retention degrades time-series bucket compaction). Strict integer parse —
# "30days" is rejected with a warn and the default kicks in.
# KANSOKU_LOGS_TTL_DAYS=30
#
# TTL for the fingerprinted `errors` registry, in days (TTL index on
# `errors_last_seen`). Same collMod reconciliation and strict-integer parse
# as the logs TTL. Defaults to 90; capped at 365.
# KANSOKU_ERRORS_TTL_DAYS=90

# === Cardinality ===
# Budget on distinct {service,component,env,level} metaField tuples tracked
# for the time-series collection. Tuples under budget pass through; once it's
# exhausted, new tuples collapse into one sentinel bucket so bucket
# cardinality can't blow up. Strict integer parse; floor 1. Defaults to 1000.
# KANSOKU_MAX_META_COMBOS=1000

# === Alerts ===
# Optional webhook fired when a brand-new error fingerprint shows up AND
# when an existing fingerprint spikes past KANSOKU_SPIKE_THRESHOLD within
# KANSOKU_SPIKE_WINDOW_MINUTES (subject to KANSOKU_SPIKE_COOLDOWN_MINUTES).
# Sends a small JSON POST body — works with Discord/Slack-style webhooks
# or any custom endpoint. Fail-open: a webhook outage never wedges ingest.
# Payload shapes:
#   { kind: "kansoku.error.new",   fingerprint, service, component, name?,
#     message, firstSeen, traceId? }
#   { kind: "kansoku.error.spike", fingerprint, service, component, name?,
#     message, count, windowMinutes, windowStart, lastSeen, traceId? }
# KANSOKU_ALERT_WEBHOOK_URL=

# Spike detection knobs. All three default to sensible values and are
# gated by KANSOKU_ALERT_WEBHOOK_URL being set — if no webhook is
# configured, evaluateSpike short-circuits before any Mongo write.
# Strict integer parse; threshold floor is 2 (threshold=1 is unreachable
# since the new-error path always pre-empts the spike path on first
# sighting), the other two have a floor of 1. Logs whose ts is older
# than KANSOKU_SPIKE_WINDOW_MINUTES are skipped so a replay/backfill
# doesn't trip the spike path even when arriving at wall-clock now.
# KANSOKU_SPIKE_THRESHOLD=10
# KANSOKU_SPIKE_WINDOW_MINUTES=5
# KANSOKU_SPIKE_COOLDOWN_MINUTES=60
