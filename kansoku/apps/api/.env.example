# HTTP server bind address. Under `portless run`, PORT is injected automatically;
# the 7779 fallback only applies when running standalone (e.g. `tsx src/server.ts`).
# KANSOKU_HOST=127.0.0.1
# PORT=7779

# Pino log level. Defaults to 'info'. Use 'debug' for request-level detail.
# LOG_LEVEL=info

# === MongoDB (Phase 1+) ===
# Connection URI for the storage layer. Defaults to the same atlas-local
# replica set the sibling services use; Kansoku writes to its own database.
# KANSOKU_MONGO_URI=mongodb://127.0.0.1:27017/?directConnection=true
# KANSOKU_MONGO_DB=kansoku

# === Ingest auth (Phase 1+) ===
# Shared HMAC token presented by sibling shippers in the `x-kansoku-auth` header.
# Rotate by updating the env var here AND in each sibling service.
# KANSOKU_INGEST_TOKEN=
