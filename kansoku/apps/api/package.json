{
  "name": "@kansoku/api",
  "version": "0.1.0",
  "description": "Observability service for the Kagami workspace — logs, traces, errors, metrics.",
  "private": true,
  "type": "module",
  "portless": "api.kansoku",
  "scripts": {
    "dev": "portless run tsx watch src/server.ts",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/ scripts/",
    "lint:fix": "eslint src/ tests/ scripts/ --fix"
  },
  "dependencies": {
    "@kagami/logger": "*",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mongodb": "^7.2.0",
    "pino-http": "^11.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@kagami/eslint-config": "*",
    "@kagami/tsconfig": "*",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "mongodb-memory-server": "^11.1.0",
    "portless": "^0.12.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  }
}
